<Window x:Class="VoidLedger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VoidLedger"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Void Ledger - Warframe Relic Tracker"
        Icon="pack://siteoforigin:,,,/images/VoidLedgerIcon.ico"
        Height="780" Width="1100"
        MinHeight="600" MinWidth="800"
        Background="#0D0F14"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        MouseDown="Window_MouseDown"
        StateChanged="Window_StateChanged">

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="5" CornerRadius="0" GlassFrameThickness="0"/>
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>

    <!-- Colors -->
    <SolidColorBrush x:Key="BgBrush"       Color="#0D0F14"/>
    <SolidColorBrush x:Key="Bg2Brush"      Color="#12151C"/>
    <SolidColorBrush x:Key="Bg3Brush"      Color="#181C26"/>
    <SolidColorBrush x:Key="BorderBrush2"  Color="#1E2433"/>
    <SolidColorBrush x:Key="TextBrush"     Color="#C8CFE0"/>
    <SolidColorBrush x:Key="TextDimBrush"  Color="#5A6478"/>
    <SolidColorBrush x:Key="TextBrightBrush" Color="#EAF0FF"/>
    <SolidColorBrush x:Key="LithBrush"     Color="#B87333"/>
    <SolidColorBrush x:Key="MesoBrush"     Color="#8E9EAB"/>
    <SolidColorBrush x:Key="NeoBrush"      Color="#D4AF37"/>
    <SolidColorBrush x:Key="AxiBrush"      Color="#A78BFA"/>
    <SolidColorBrush x:Key="CommonBrush"   Color="#7EB3D4"/>
    <SolidColorBrush x:Key="UncommonBrush" Color="#89C89E"/>
    <SolidColorBrush x:Key="RareBrush"     Color="#E8C553"/>
    <SolidColorBrush x:Key="LegendaryBrush" Color="#CC5577"/>

    <!-- MenuItem style (removes icon column) -->
    <Style TargetType="MenuItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd"
                Background="{TemplateBinding Background}"
                Padding="12,6">
                        <ContentPresenter ContentSource="Header"
                            RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                    Value="#1E2433"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="#12151C"/>
        <Setter Property="BorderBrush" Value="#1E2433"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            Padding="{TemplateBinding Padding}">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
      
        <!-- Tab button style -->
    <Style x:Key="TabBtnStyle" TargetType="RadioButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0,0,0,3"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Foreground" Value="#5A6478"/>
      <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="20,10"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsChecked" Value="True">
          <Setter Property="Foreground" Value="#EAF0FF"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Foreground" Value="#C8CFE0"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Filter toggle button style -->
    <Style x:Key="FilterBtnStyle" TargetType="ToggleButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#1E2433"/>
      <Setter Property="Foreground" Value="#5A6478"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsChecked" Value="True">
          <Setter Property="BorderBrush" Value="#A78BFA"/>
          <Setter Property="Foreground" Value="#EAF0FF"/>
          <Setter Property="Background" Value="#1a1630"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="#A78BFA"/>
          <Setter Property="Foreground" Value="#C8CFE0"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Sort button style -->
    <Style x:Key="SortBtnStyle" TargetType="RadioButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#1E2433"/>
      <Setter Property="Foreground" Value="#5A6478"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsChecked" Value="True">
          <Setter Property="BorderBrush" Value="#A78BFA"/>
          <Setter Property="Foreground" Value="#EAF0FF"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="#A78BFA"/>
          <Setter Property="Foreground" Value="#C8CFE0"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Load button -->
    <Style x:Key="LoadBtnStyle" TargetType="Button">
      <Setter Property="Background" Value="#A78BFA"/>
      <Setter Property="Foreground" Value="#0D0F14"/>
      <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="22,8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#9370e8"/>
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Background" Value="#3a2f5e"/>
          <Setter Property="Foreground" Value="#5A6478"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Scrollbar style (slim dark) -->
    <Style TargetType="ScrollBar">
      <Setter Property="Width" Value="6"/>
      <Setter Property="Background" Value="#12151C"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid>
              <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.Thumb>
                  <Thumb>
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Border Background="#2e364a" CornerRadius="3"/>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/> <!-- header -->
      <RowDefinition Height="Auto"/> <!-- controls -->
      <RowDefinition Height="Auto"/> <!-- tabs -->
      <RowDefinition Height="Auto"/> <!-- sort bar -->
      <RowDefinition Height="*"/>    <!-- content -->
      <RowDefinition Height="Auto"/> <!-- footer -->
    </Grid.RowDefinitions>

    <!--  HEADER  -->
    <Border Grid.Row="0" BorderBrush="#1E2433" BorderThickness="0" Padding="32,22,32,16">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
        <Image Source="pack://siteoforigin:,,,/images/VoidLedgerIcon.ico"
               Width="34" Height="34" Margin="0,0,14,0"
               VerticalAlignment="Center"/>
        <TextBlock FontFamily="Segoe UI Black" FontSize="26"
                   Foreground="#EAF0FF">VOID </TextBlock>
        <TextBlock FontFamily="Segoe UI Black" FontSize="26"
                   Foreground="#A78BFA">LEDGER</TextBlock>
        <TextBlock x:Name="VersionLabel" FontFamily="Segoe UI" FontSize="10"
                   Foreground="#5A6478" Margin="12,0,0,4"
                   VerticalAlignment="Bottom"/>
      </StackPanel>
    </Border>

    <!--  CONTROLS  -->
    <Border Grid.Row="1" BorderBrush="#1E2433" BorderThickness="0,0,0,1" Padding="32,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
          <Button x:Name="LoadButton" Content="LOAD ALL RELICS"
                  Style="{StaticResource LoadBtnStyle}"
                  Click="LoadButton_Click"/>
          <StackPanel x:Name="ProgressPanel" Orientation="Horizontal"
                      Margin="16,0,0,0" VerticalAlignment="Center"
                      Visibility="Collapsed">
            <ProgressBar x:Name="ProgressBar" Width="280" Height="4"
                         Background="#1E2433" Foreground="#A78BFA"
                         BorderThickness="0" Minimum="0" Maximum="100"/>
            <TextBlock x:Name="ProgressLabel" Margin="12,0,0,0"
                       Foreground="#5A6478" FontSize="12" VerticalAlignment="Center"
                       Text="Initializing…"/>
          </StackPanel>
          <TextBlock x:Name="StatusLabel" Margin="16,0,0,0"
                     Foreground="#5A6478" FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>
        <Button Grid.Column="2" Content="FULLSCREEN"
                Style="{StaticResource LoadBtnStyle}"
                Click="Fullscreen_Click" Margin="0,0,8,0"/>
        <Button Grid.Column="3" Content="EXIT"
                Style="{StaticResource LoadBtnStyle}"
                Click="Exit_Click"/>
      </Grid>
    </Border>

    <!--  TIER TABS  -->
    <Border x:Name="TierTabBar" Grid.Row="2" BorderBrush="#1E2433" BorderThickness="0,0,0,1"
            Padding="20,0" Visibility="Collapsed">
      <StackPanel Orientation="Horizontal">
        <RadioButton x:Name="TabLith" Content="LITH" GroupName="Tier"
                     Style="{StaticResource TabBtnStyle}" IsChecked="True"
                     Checked="Tab_Checked">
          <RadioButton.Resources>
            <Style TargetType="RadioButton" BasedOn="{StaticResource TabBtnStyle}">
              <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Setter Property="BorderBrush" Value="#B87333"/>
                  <Setter Property="Foreground" Value="#B87333"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </RadioButton.Resources>
        </RadioButton>
        <RadioButton x:Name="TabMeso" Content="MESO" GroupName="Tier"
                     Style="{StaticResource TabBtnStyle}"
                     Checked="Tab_Checked">
          <RadioButton.Resources>
            <Style TargetType="RadioButton" BasedOn="{StaticResource TabBtnStyle}">
              <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Setter Property="BorderBrush" Value="#8E9EAB"/>
                  <Setter Property="Foreground" Value="#8E9EAB"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </RadioButton.Resources>
        </RadioButton>
        <RadioButton x:Name="TabNeo" Content="NEO" GroupName="Tier"
                     Style="{StaticResource TabBtnStyle}"
                     Checked="Tab_Checked">
          <RadioButton.Resources>
            <Style TargetType="RadioButton" BasedOn="{StaticResource TabBtnStyle}">
              <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Setter Property="BorderBrush" Value="#D4AF37"/>
                  <Setter Property="Foreground" Value="#D4AF37"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </RadioButton.Resources>
        </RadioButton>
        <RadioButton x:Name="TabAxi" Content="AXI" GroupName="Tier"
                     Style="{StaticResource TabBtnStyle}"
                     Checked="Tab_Checked">
          <RadioButton.Resources>
            <Style TargetType="RadioButton" BasedOn="{StaticResource TabBtnStyle}">
              <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Setter Property="BorderBrush" Value="#A78BFA"/>
                  <Setter Property="Foreground" Value="#A78BFA"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </RadioButton.Resources>
        </RadioButton>
      </StackPanel>
    </Border>

    <!--  SORT BAR  -->
    <Border x:Name="SortBar" Grid.Row="3" BorderBrush="#1E2433" BorderThickness="0,0,0,1"
            Padding="32,8" Visibility="Collapsed">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
          <TextBlock Text="Sort:" Foreground="#5A6478" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <RadioButton Content="Name" GroupName="Sort" Style="{StaticResource SortBtnStyle}"
                       IsChecked="True" Checked="Sort_Checked" Tag="name" Margin="0,0,4,0"/>
          <RadioButton Content="Total ↓" GroupName="Sort" Style="{StaticResource SortBtnStyle}"
                       Checked="Sort_Checked" Tag="total-desc" Margin="0,0,4,0"/>
          <RadioButton Content="Total ↑" GroupName="Sort" Style="{StaticResource SortBtnStyle}"
                       Checked="Sort_Checked" Tag="total-asc" Margin="0,0,4,0"/>

          <Border Width="1" Background="#1E2433" Margin="10,2,10,2" VerticalAlignment="Stretch"/>

          <TextBlock Text="Filter:" Foreground="#5A6478" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <ToggleButton x:Name="FilterOwned" Content="Owned"
                        Style="{StaticResource FilterBtnStyle}"
                        Checked="Filter_Changed" Unchecked="Filter_Changed"
                        Margin="0,0,4,0"/>
          <ToggleButton x:Name="FilterUnvaulted" Content="Unvaulted"
                        Style="{StaticResource FilterBtnStyle}"
                        Checked="Filter_Changed" Unchecked="Filter_Changed"/>
        </StackPanel>

        <TextBlock x:Name="CountLabel" Grid.Column="1" Margin="20,0,0,0"
                   Foreground="#5A6478" FontSize="11" VerticalAlignment="Center"/>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                        Margin="20,0,0,0" Height="32">
            <StackPanel x:Name="SelectionPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
          </ScrollViewer>
          <Button x:Name="SquadButton"
                  Content="SQUAD"
                  Style="{StaticResource LoadBtnStyle}"
                  Visibility="Collapsed"
                  Click="SquadButton_Click"
                  Margin="12,0,0,0"/>
        </StackPanel>
      </Grid>
    </Border>

    <!--  RELIC LIST  -->
    <ScrollViewer Grid.Row="4" x:Name="MainScroller"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="#0D0F14">
      <StackPanel x:Name="RelicListPanel" Margin="32,16,32,32"/>
    </ScrollViewer>

    <!--  FOOTER  -->
    <Border x:Name="FooterBar" Grid.Row="5" BorderBrush="#1E2433" BorderThickness="0,1,0,0" Padding="32,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="SearchLabel" Grid.Column="0"
                   Text="Search: " Foreground="#5A6478" FontSize="11"
                   VerticalAlignment="Center" Margin="0,0,4,0"
                   Visibility="Collapsed"/>
        <TextBox x:Name="SearchBox" Grid.Column="1"
                 Background="#12151C" Foreground="#C8CFE0" BorderBrush="#1E2433" BorderThickness="1"
                 Padding="8,4" FontSize="11"
                 TextChanged="SearchBox_TextChanged"
                 Margin="0,0,12,0" VerticalAlignment="Center"
                 Visibility="Collapsed"/>
        <TextBlock x:Name="ShortcutHint" Grid.Column="2"
                   Text="CTRL+CLICK to select  /  SHIFT+CLICK to mark owned"
                   Foreground="#5A6478" FontSize="10"
                   VerticalAlignment="Center" HorizontalAlignment="Left"
                   Visibility="Collapsed"/>
        <TextBlock Grid.Column="4"
                   Text="Using data from warframe.market and drops.warframestat.us"
                   Foreground="#5A6478" FontSize="10"
                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
      </Grid>
    </Border>

  </Grid>
</Window>
